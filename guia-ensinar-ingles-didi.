<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guia da Professora — Didi ensina inglês</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#F4F8F4;color:#1A1A1A;line-height:1.6}

/* HERO */
.hero{background:linear-gradient(135deg,#1B6B4A 0%,#2D9B6E 60%,#3BBEC0 100%);padding:48px 36px 40px;color:#fff}
.hero-tag{font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.65);margin-bottom:10px}
.hero-title{font-size:36px;font-weight:700;line-height:1.15;margin-bottom:8px}
.hero-sub{font-size:15px;color:rgba(255,255,255,0.78);max-width:520px}

/* LAYOUT */
.wrap{max-width:780px;margin:0 auto;padding:36px 24px 80px}

/* SECTION */
.sec{margin-bottom:40px}
.sec-num{font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#2D9B6E;margin-bottom:6px}
.sec-title{font-size:21px;font-weight:700;color:#1A1A1A;margin-bottom:4px}
.sec-sub{font-size:13px;color:#666;margin-bottom:20px}

/* PRINCIPLE CARDS */
.principles{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:6px}
.princ{background:#fff;border:1px solid #E4EDE7;border-radius:12px;padding:16px;border-left:4px solid}
.princ-icon{font-size:22px;margin-bottom:8px}
.princ-title{font-size:13px;font-weight:700;color:#1A1A1A;margin-bottom:4px}
.princ-body{font-size:12px;color:#555;line-height:1.55}
.princ-tip{font-size:11px;color:#2D9B6E;font-weight:600;margin-top:6px;padding-top:6px;border-top:1px dashed #D0EAD8}

/* STEPS */
.steps{counter-reset:step}
.step{display:flex;gap:16px;padding:16px 0;border-bottom:1px solid #EEF3EF}
.step:last-child{border-bottom:none}
.step-num{width:36px;height:36px;border-radius:50%;background:#2D9B6E;color:#fff;font-size:15px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.step-content{}
.step-title{font-size:14px;font-weight:700;color:#1A1A1A;margin-bottom:3px}
.step-body{font-size:12.5px;color:#444;line-height:1.55}
.step-action{font-size:11.5px;background:#EBF7EF;color:#1B6B4A;padding:5px 10px;border-radius:6px;margin-top:7px;display:inline-block;font-weight:600}

/* CHECKLIST */
.checklist-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.cl-card{background:#fff;border:1px solid #E4EDE7;border-radius:12px;overflow:hidden}
.cl-head{padding:12px 16px;font-size:13px;font-weight:700;color:#fff}
.cl-body{padding:14px 16px}
.cl-phase{font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#999;margin:10px 0 5px}
.cl-phase:first-child{margin-top:0}
.cl-item{display:flex;gap:8px;align-items:flex-start;padding:4px 0;font-size:12px;color:#333;line-height:1.45}
.cl-item::before{content:"☐";font-size:13px;flex-shrink:0;color:#AAA;margin-top:0px}
.cl-time{font-size:10px;color:#999;margin-left:auto;flex-shrink:0;padding-left:6px;white-space:nowrap}

/* BLUEPRINT */
.blueprint{margin-top:4px}
.bp-legend{display:flex;gap:20px;margin-bottom:20px;flex-wrap:wrap}
.bp-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:4px}
.bp-leg-item{display:flex;align-items:flex-start;gap:7px;font-size:12px;color:#555}
.bp-leg-label{font-weight:600;color:#333;display:block;font-size:11px}

.month-block{margin-bottom:24px;border:1px solid #E4EDE7;border-radius:14px;overflow:hidden;background:#fff}
.month-head{padding:12px 20px;display:flex;align-items:center;gap:12px}
.month-num{font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.8)}
.month-title{font-size:16px;font-weight:700;color:#fff}
.month-milestone{font-size:11px;color:rgba(255,255,255,0.7);margin-left:auto;white-space:nowrap}
.month-cols{display:grid;grid-template-columns:1fr 1fr 1fr;border-top:1px solid #F0F0F0}
.month-col{padding:14px 16px;border-right:1px solid #F0F0F0}
.month-col:last-child{border-right:none}
.col-tag{font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:8px;padding-bottom:5px;border-bottom:1px dashed}
.col-item{font-size:11.5px;color:#333;padding:3px 0 3px 12px;position:relative;line-height:1.45}
.col-item::before{content:"·";position:absolute;left:3px;color:#AAA}
.col-item strong{color:#1A1A1A;font-weight:600}
.col-item.goal{background:#F0FAF5;border-radius:5px;padding:4px 8px 4px 20px;margin-top:4px}
.col-item.goal::before{content:"✓";color:#2D9B6E;font-size:10px}

/* FOOTER NOTE */
.foot-note{background:#1B6B4A;color:rgba(255,255,255,0.85);padding:20px 24px;border-radius:12px;font-size:13px;line-height:1.7;margin-top:16px}
.foot-note strong{color:#fff}

@media(max-width:560px){
  .principles{grid-template-columns:1fr}
  .checklist-grid{grid-template-columns:1fr}
  .month-cols{grid-template-columns:1fr}
  .month-col{border-right:none;border-bottom:1px solid #F0F0F0}
  .month-col:last-child{border-bottom:none}
  .hero-title{font-size:26px}
}
</style>
</head>
<body>

<div class="hero">
  <div class="hero-tag">Guia da Professora</div>
  <div class="hero-title">Didi ensina inglês<br>do zero ao A1/A2</div>
  <div class="hero-sub">Lorenzo (11 anos) · Lucas (7 anos) · 6 meses · tudo que precisas saber para começar hoje</div>
</div>

<div class="wrap">

<!-- ═══════════════════════════════════════════════════════
     1. PRINCÍPIOS BÁSICOS
════════════════════════════════════════════════════════ -->
<div class="sec">
  <div class="sec-num">Parte 1</div>
  <div class="sec-title">Princípios básicos de ensino para crianças</div>
  <div class="sec-sub">O que a neurociência e a pedagogia dizem sobre como crianças realmente aprendem línguas.</div>

  <div class="principles">

    <div class="princ" style="border-left-color:#2D9B6E">
      <div class="princ-icon">⏱️</div>
      <div class="princ-title">A atenção é curta — e isso é normal</div>
      <div class="princ-body">O Lucas tem 7–10 minutos de foco intenso. O Lorenzo, 15–20 min por tarefa. Não é falta de empenho — é desenvolvimento neurológico. Aulas longas com um único formato não funcionam. A estrutura de 5 momentos distintos existe por isso: o cérebro precisa de quebras e variedade para consolidar o que aprendeu.</div>
      <div class="princ-tip">→ Nunca uma actividade por mais de 12 minutos para o Lucas. Troca o formato, não o tema.</div>
    </div>

    <div class="princ" style="border-left-color:#3BBEC0">
      <div class="princ-icon">🎮</div>
      <div class="princ-title">O jogo é o trabalho sério da criança</div>
      <div class="princ-body">Quando a criança joga, o hipocampo (memória de longo prazo) está mais activo do que em qualquer outra actividade. Jogos não são prémio depois da aula — são o método. Simon Says, Memory, Wordwall Gameshow, flashcards com pontuação: tudo isso é pedagogia de alta eficácia, não entretenimento.</div>
      <div class="princ-tip">→ Se precisares escolher entre "ensinar" e "jogar", joga sempre. O vocabulário vai ficar.</div>
    </div>

    <div class="princ" style="border-left-color:#F0A500">
      <div class="princ-icon">🔁</div>
      <div class="princ-title">Repetição lúdica — não repetição mecânica</div>
      <div class="princ-body">Uma criança precisa de encontrar uma palavra nova 7–12 vezes em contextos diferentes para a incorporar. A diferença entre decorar e aprender é o contexto: dizer "cat" vinte vezes numa lista não funciona. Dizer "cat" numa canção, num jogo, numa história e num desenho — isso fica para sempre. Repete os temas, não os exercícios.</div>
      <div class="princ-tip">→ O mesmo vocabulário aparece no jogo, na canção, no desenho e na conversa. Isso é planeamento.</div>
    </div>

    <div class="princ" style="border-left-color:#9B59B6">
      <div class="princ-icon">👂</div>
      <div class="princ-title">Listening e Speaking primeiro — sempre</div>
      <div class="princ-body">É exactamente como aprendemos a falar a língua materna: anos a ouvir antes de falar, anos a falar antes de ler, e só depois a escrever. Crianças que tentam aprender inglês "pelo livro" sofrem porque o sequenciamento natural está invertido. O Lucas não precisa de ler "cat" — precisa de ouvir, imitar e depois reconhecer. O Lorenzo pode já usar um pouco de escrita, mas a fala lidera.</div>
      <div class="princ-tip">→ Para Lucas: 80% listening/speaking, 20% visual. Para Lorenzo: 60/40. Zero gramática no papel no 1º mês.</div>
    </div>

    <div class="princ" style="border-left-color:#E74C3C">
      <div class="princ-icon">❤️</div>
      <div class="princ-title">A relação é o método</div>
      <div class="princ-body">O neurocientista Humberto Maturana mostrou que aprendemos em redes de afecto. Uma criança aprende mais rápido com alguém em quem confia do que com qualquer método. O facto de seres a tia não é uma desvantagem pedagógica — é o teu maior activo. Errar contigo é seguro. Tentar contigo é seguro. E é nessa segurança que a língua entra.</div>
      <div class="princ-tip">→ Quando uma aula "não funciona", raramente é o conteúdo. Verifica a relação, a energia, o cansaço.</div>
    </div>

    <div class="princ" style="border-left-color:#1ABC9C">
      <div class="princ-icon">🎯</div>
      <div class="princ-title">Menos é mais — máximo 5 palavras novas por aula</div>
      <div class="princ-body">A memória de trabalho de uma criança processa 4–7 itens novos por sessão. Mais do que isso e nada fica. Prefere sempre introduzir 4 palavras bem contextualizadas do que 20 palavras numa lista. A profundidade de uso importa mais do que a largura do vocabulário. Revisão > introdução nova. Sempre.</div>
      <div class="princ-tip">→ Regra de ouro: se saíste da aula e introduziste 3 coisas novas, foi uma boa aula. Não 15.</div>
    </div>

  </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     2. 5 PASSOS PARA APRENDER A ENSINAR DO ZERO
════════════════════════════════════════════════════════ -->
<div class="sec">
  <div class="sec-num">Parte 2</div>
  <div class="sec-title">5 passos para aprender a ensinar do zero</div>
  <div class="sec-sub">Do planeamento à avaliação — sem jargão pedagógico, só o essencial.</div>

  <div class="step">
    <div class="step-num">1</div>
    <div class="step-content">
      <div class="step-title">Aprende a estrutura antes do conteúdo</div>
      <div class="step-body">Antes de pensar "o que vou ensinar?", tens de ter clara a estrutura dos 5 momentos de cada aula (ritual → revisão → conteúdo → criação → encerramento). Quando a estrutura está automática, podes focar energia no conteúdo e na relação — não na logística. Passa as primeiras duas semanas a praticar só a estrutura, com qualquer vocabulário simples que já saibas.</div>
      <div class="step-action">Acção agora: Imprime o checklist diário desta página. Usa-o nas primeiras 6 aulas sem falhar.</div>
    </div>
  </div>

  <div class="step">
    <div class="step-num">2</div>
    <div class="step-content">
      <div class="step-title">Planeia em 3 camadas: mês, semana, aula</div>
      <div class="step-body">Camada 1 — O que queremos alcançar este mês? (ex: vocabulário de animais + "I like / I don't like"). Camada 2 — O que vamos explorar esta semana dentro do projecto? Camada 3 — O que fazemos hoje, passo a passo, com timing? Não precisas de um plano perfeito — precisas de uma direcção clara e materiais prontos. Improviso é para professores experientes. Tu precisas de preparação.</div>
      <div class="step-action">Acção agora: Antes de cada aula, escreve em 3 linhas: tema, 3 actividades e uma frase que queres que eles digam no fim.</div>
    </div>
  </div>

  <div class="step">
    <div class="step-num">3</div>
    <div class="step-content">
      <div class="step-title">Observa primeiro, corrige depois — e raramente</div>
      <div class="step-body">O maior erro de professores iniciantes é corrigir em excesso. Cada correcção interrompe o fluxo e envia ao cérebro um sinal de alarme que inibe a produção. A técnica correcta chama-se "recast": o aluno diz "I goed to school", tu respondes naturalmente "oh, you went to school! cool, and what did you do there?" — a forma correcta entrou sem humilhação. Para o Lucas, zero correcções explícitas. Para o Lorenzo, no máximo uma por aula, e apenas quando ele próprio pediu ajuda.</div>
      <div class="step-action">Acção agora: Em vez de "not quite" ou "that's wrong", usa sempre "nice try! it's actually ___" e continua.</div>
    </div>
  </div>

  <div class="step">
    <div class="step-num">4</div>
    <div class="step-content">
      <div class="step-title">Mantém um diário de 3 linhas por aula</div>
      <div class="step-body">Não um relatório. Três linhas no telemóvel depois de cada aula: O que funcionou? O que não funcionou? O que quero testar na próxima? Isto é avaliação real. Professores experientes chamam-lhe "reflexão docente" — a única forma de melhorar sem um supervisor. Ao fim de 6 semanas vais ter um padrão claro: o que funciona com o Lorenzo, o que funciona com o Lucas, o que não funciona de todo.</div>
      <div class="step-action">Acção agora: Cria uma nota no telemóvel chamada "Diário Aulas" e escreve depois da primeira sessão.</div>
    </div>
  </div>

  <div class="step">
    <div class="step-num">5</div>
    <div class="step-content">
      <div class="step-title">Avalia pelo engajamento e pela produção — não pela performance</div>
      <div class="step-body">Não há testes neste método. A avaliação acontece todos os dias, observando: eles pedem para continuar? Usam inglês espontaneamente fora da aula? Fazem perguntas em inglês? Riem de uma piada em inglês? Corrigem-se sem serem corrigidos? Essas são as evidências reais de aquisição de língua. No fim de cada bloco de 3 semanas, revê os artefactos produzidos (o desenho do Lucas, o texto do Lorenzo) — são o teu "boletim".</div>
      <div class="step-action">Acção agora: Guarda uma foto do primeiro produto de cada um. Ao fim de 3 meses, compara — vais ficar surpreendida.</div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════
     3. CHECKLIST DIÁRIO
════════════════════════════════════════════════════════ -->
<div class="sec">
  <div class="sec-num">Parte 3</div>
  <div class="sec-title">Checklist diário de aula</div>
  <div class="sec-sub">Imprime, plastifica, usa. Versão Lorenzo (60 min) e versão Lucas (30 min).</div>

  <div class="checklist-grid">

    <!-- LORENZO -->
    <div class="cl-card">
      <div class="cl-head" style="background:#2D9B6E">Lorenzo — 50 a 60 min</div>
      <div class="cl-body">

        <div class="cl-phase">Antes (5 min)</div>
        <div class="cl-item">Tenho o tema e os materiais prontos<span class="cl-time">-5 min</span></div>
        <div class="cl-item">Sei qual é a nova estrutura/vocabulário de hoje<span class="cl-time"></span></div>
        <div class="cl-item">Tenho um "plano B" se ele resistir ao plano A<span class="cl-time"></span></div>

        <div class="cl-phase">Check-in (5 min)</div>
        <div class="cl-item">Conversa real em inglês: "how was your week?"<span class="cl-time">5'</span></div>
        <div class="cl-item">Confirmei/ajustei o projecto em curso com ele<span class="cl-time"></span></div>

        <div class="cl-phase">Revisão / Jogo (10 min)</div>
        <div class="cl-item">Actividade de revisão do vocabulário anterior<span class="cl-time">10'</span></div>
        <div class="cl-item">Tem pontuação ou desafio (não é só "lembras?")<span class="cl-time"></span></div>

        <div class="cl-phase">Projecto principal (20–25 min)</div>
        <div class="cl-item">Vídeo / leitura / pesquisa / debate<span class="cl-time">20–25'</span></div>
        <div class="cl-item">Introduzi nova estrutura no contexto (não na regra)<span class="cl-time"></span></div>
        <div class="cl-item">Fiz no máximo 1 correcção — e só quando ele pediu<span class="cl-time"></span></div>

        <div class="cl-phase">Produção autoral (12–15 min)</div>
        <div class="cl-item">Ele criou algo real: review / texto / script / guia<span class="cl-time">12–15'</span></div>
        <div class="cl-item">O produto é para comunicar algo, não para cumprir<span class="cl-time"></span></div>

        <div class="cl-phase">Reflexão (3–5 min)</div>
        <div class="cl-item">"What did you learn? What surprised you?"<span class="cl-time">3–5'</span></div>
        <div class="cl-item">Ele escolheu algo para a próxima aula<span class="cl-time"></span></div>

        <div class="cl-phase">Depois (2 min)</div>
        <div class="cl-item">Guardei o produto / foto do trabalho<span class="cl-time"></span></div>
        <div class="cl-item">Escrevi 3 linhas no diário<span class="cl-time"></span></div>
      </div>
    </div>

    <!-- LUCAS -->
    <div class="cl-card">
      <div class="cl-head" style="background:#3BBEC0">Lucas — 25 a 30 min</div>
      <div class="cl-body">

        <div class="cl-phase">Antes (3 min)</div>
        <div class="cl-item">Materiais na mão: flashcards, papel, crayons<span class="cl-time">-3 min</span></div>
        <div class="cl-item">Sei a canção de abertura e encerramento de hoje<span class="cl-time"></span></div>
        <div class="cl-item">Tenho a sacola/caixa misteriosa se precisar<span class="cl-time"></span></div>

        <div class="cl-phase">Ritual de abertura (3 min)</div>
        <div class="cl-item">Mesma canção de sempre — sem excepções<span class="cl-time">3'</span></div>
        <div class="cl-item">Energia alta, contacto visual, sorriso<span class="cl-time"></span></div>

        <div class="cl-phase">Revisão lúdica (5 min)</div>
        <div class="cl-item">Simon Says / flashcards / sacola misteriosa<span class="cl-time">5'</span></div>
        <div class="cl-item">Ele mexeu no corpo — não ficou só a ouvir<span class="cl-time"></span></div>

        <div class="cl-phase">Conteúdo novo (10 min)</div>
        <div class="cl-item">Introduzido via história OU música OU jogo<span class="cl-time">10'</span></div>
        <div class="cl-item">Máximo 5 palavras novas — dentro do projecto<span class="cl-time"></span></div>
        <div class="cl-item">Ele repetiu as palavras em contexto (não em lista)<span class="cl-time"></span></div>

        <div class="cl-phase">Actividade criativa (7 min)</div>
        <div class="cl-item">Desenhou / colou / montou / moveu o corpo<span class="cl-time">7'</span></div>
        <div class="cl-item">Produziu algo com as mãos que representa o que aprendeu<span class="cl-time"></span></div>

        <div class="cl-phase">Ritual de encerramento (3 min)</div>
        <div class="cl-item">Mesma goodbye song ou frase ritual — sempre igual<span class="cl-time">3'</span></div>
        <div class="cl-item">Terminou com energia positiva<span class="cl-time"></span></div>

        <div class="cl-phase">Depois (2 min)</div>
        <div class="cl-item">Foto do produto/desenho guardada<span class="cl-time"></span></div>
        <div class="cl-item">3 linhas no diário: o que funcionou<span class="cl-time"></span></div>
      </div>
    </div>

  </div>
</div>


<!-- ═══════════════════════════════════════════════════════
     4. BLUEPRINT — DUAS JORNADAS
════════════════════════════════════════════════════════ -->
<div class="sec">
  <div class="sec-num">Parte 4</div>
  <div class="sec-title">Blueprint: a jornada em 6 meses</div>
  <div class="sec-sub">Três colunas por mês — o que Didi faz/aprende, o que o Lorenzo experiencia e produz, o que o Lucas experiencia e produz. Marcos mensais: avaliação observacional a cada 4 semanas.</div>

  <div class="bp-legend">
    <div class="bp-leg-item"><div class="bp-dot" style="background:#2D6A4F;margin-top:4px"></div><div><span class="bp-leg-label">Didi (professora)</span>tarefas, aprendizagem didáctica, foco da aula</div></div>
    <div class="bp-leg-item"><div class="bp-dot" style="background:#2AAFB8;margin-top:4px"></div><div><span class="bp-leg-label">Lorenzo (11 anos)</span>experiência, tarefas e marcos de aquisição</div></div>
    <div class="bp-leg-item"><div class="bp-dot" style="background:#F0A500;margin-top:4px"></div><div><span class="bp-leg-label">Lucas (7 anos)</span>experiência, tarefas e marcos de aquisição</div></div>
  </div>

  <div class="blueprint">

    <!-- MÊS 1 -->
    <div class="month-block">
      <div class="month-head" style="background:linear-gradient(90deg,#1B6B4A,#2D9B6E)">
        <div>
          <div class="month-num">Mês 1</div>
          <div class="month-title">Fundação — ritmo, segurança, primeiras palavras</div>
        </div>
        <div class="month-milestone">Foco: Listening + Speaking puro</div>
      </div>
      <div class="month-cols">
        <div class="month-col">
          <div class="col-tag" style="color:#2D6A4F;border-color:#C8E6C9">🎓 Didi aprende e faz</div>
          <div class="col-item">Memoriza a estrutura dos 5 momentos até estar automática</div>
          <div class="col-item">Escolhe UMA canção de abertura para cada sobrinho — não muda no mês 1</div>
          <div class="col-item">Prepara flashcards físicos dos primeiros 20 vocábulos (animais + cores + números)</div>
          <div class="col-item">Cria o diário de 3 linhas no telemóvel</div>
          <div class="col-item">Faz 4 aulas (1/semana cada) — não mais</div>
          <div class="col-item"><strong>Foco didáctico:</strong> Fala inglês o tempo todo. Usa o português só para garantir segurança emocional</div>
          <div class="col-item goal">Meta Didi: terminar o mês com a estrutura automática e 3 linhas de diário por aula</div>
        </div>
        <div class="month-col">
